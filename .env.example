# Copiá este archivo como .env para probar localmente con `netlify dev`.
# En producción, estas variables se configuran en:
# Netlify > Site configuration > Environment variables

# Obtenela gratis en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opcional. Si no se define, se usa "gemini-2.5-flash" (rápido, barato, multimodal).
# Otras opciones válidas a junio 2026: gemini-3.1-flash-lite, gemini-3.5-flash, gemini-3.1-pro-preview
GEMINI_MODEL=gemini-2.5-flash
